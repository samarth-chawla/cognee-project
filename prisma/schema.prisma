generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InterviewStatus {
  PENDING
  GENERATING
  READY
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum InterviewMode {
  VOICE
  TEXT
  HYBRID
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id              String              @id @default(cuid())
  clerkId         String              @unique
  email           String              @unique
  fullName        String?
  profile         UserProfile?
  resumes         Resume[]
  jobDescriptions JobDescription[]
  interviews      Interview[]
  answers         Answer[]
  analytics       InterviewAnalytics?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([clerkId])
  @@index([email])
}

model UserProfile {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience             String?
  githubUrl              String?
  linkedinUrl            String?
  targetRole             String?
  preferredInterviewMode InterviewMode @default(VOICE)
  preferredDifficulty    Difficulty    @default(MEDIUM)
  targetCompanies        String[]
  interviewTypes         String[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([targetRole])
}

model Resume {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl          String
  originalFileName String
  storedFileName   String
  fileSize         Int
  mimeType         String
  pageCount        Int
  rawText          String
  uploadedAt       DateTime    @default(now())
  interviews       Interview[]

  @@index([userId])
  @@index([storedFileName])
  @@index([uploadedAt])
}

model JobDescription {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  title        String
  fileUrl      String?
  rawText      String?
  parsedSkills String[]
  uploadedAt   DateTime    @default(now())
  interviews   Interview[]

  @@index([userId])
  @@index([company])
  @@index([title])
  @@index([uploadedAt])
}

model Interview {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId         String?
  resume           Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescriptionId String?
  jobDescription   JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  company          String?
  companyType      String?
  customCompanyName String?
  role             String
  interviewType    String?
  difficulty       Difficulty?
  status           InterviewStatus @default(PENDING)
  startedAt        DateTime?
  endedAt          DateTime?
  questions        Json?
  answer           Answer?
  report           Report?
  reportGenerationJob ReportGenerationJob?
  pipelineUsage    InterviewPipelineUsage?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([userId, status, updatedAt])
  @@index([resumeId])
  @@index([jobDescriptionId])
  @@index([status])
  @@index([createdAt])
}

model Answer {
  id         String   @id @default(cuid())
  interviewId String  @unique
  interview  Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Report {
  id                  String    @id @default(cuid())
  interviewId         String    @unique
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  overallScore        Float
  technicalScore      Float
  communicationScore  Float
  confidenceScore     Float
  behavioralScore     Float
  problemSolvingScore Float
  strengths           String[]
  weaknesses          String[]
  missingTopics       String[]
  recommendations     String[]
  createdAt           DateTime  @default(now())

  @@index([overallScore])
  @@index([createdAt])
}

model InterviewAnalytics {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalInterviews Int      @default(0)
  averageScore    Float    @default(0)
  currentStreak   Int      @default(0)
  readinessScore  Float    @default(0)
  updatedAt       DateTime @updatedAt

  @@index([readinessScore])
}

// Tombstone: immutable record of a deleted account. Survives the hard-delete of
// the User row so we keep knowledge of who left and how much they used. Keyed on
// email (stable identity) — clerkId changes on every re-signup, so email is the
// anchor that stops "delete + re-create" from resetting the usage limit.
model AccountDeletionLog {
  id         String   @id @default(cuid())
  clerkId    String
  email      String
  fullName   String?
  usedCount  Int      @default(0)
  reason     String?
  source     String   @default("clerk-webhook")
  deletedAt  DateTime @default(now())

  @@index([clerkId])
  @@index([email])
  @@index([deletedAt])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobFailureReason {
  RATE_LIMITED
  SERVICE_UNAVAILABLE
  NETWORK_ERROR
  UNKNOWN
}

model ReportGenerationJob {
  id            String            @id @default(cuid())
  interviewId   String            @unique
  interview     Interview         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId        String
  status        JobStatus         @default(PENDING)
  failureReason JobFailureReason?
  retryCount    Int               @default(0)
  nextRetryAt   DateTime          @default(now())
  lastError     String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, nextRetryAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pipeline Observability
// ─────────────────────────────────────────────────────────────────────────────

enum PipelineExecutionStatus {
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  ABANDONED
}

enum PipelineStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  SKIPPED
}

enum PipelineAbortReason {
  USER_CANCELLED
  REPORT_FAILED
  STALE_TIMEOUT
  PIPELINE_ERROR
  INTERVIEW_FAILED
  SYSTEM_SHUTDOWN
}

enum PipelineFailureReason {
  NONE
  RATE_LIMITED
  TIMEOUT
  NETWORK_ERROR
  SERVICE_UNAVAILABLE
  DATABASE_ERROR
  AUTH_ERROR
  PROVIDER_ERROR
  INVALID_INPUT
  UNKNOWN
}

/**
 * One-to-one with Interview.
 * Tracks cost, latency, tokens, provider health, and failure data for every
 * stage of the Clutchly AI pipeline.
 * Used by: Admin Dashboard, AI Cost Tracking, Billing Analytics, Provider Health.
 */
model InterviewPipelineUsage {
  id          String    @id @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId      String

  // ── Overall Pipeline ──────────────────────────────────────────────────────
  pipelineStatus          PipelineExecutionStatus @default(PROCESSING)
  pipelineAbortReason     PipelineAbortReason?
  pipelineCompletedBy     String?
  pipelineStartedAt       DateTime?
  pipelineCompletedAt     DateTime?
  totalPipelineDurationMs Int            @default(0)
  totalPipelineCostUsd    Decimal        @default(0) @db.Decimal(12, 8)
  currency                String         @default("USD")
  pricingVersion          String         @default("")
  pipelineVersion         String         @default("")
  isFirstInterview        Boolean        @default(false)

  // ── Interview Metadata (denormalized for dashboards — no joins needed) ────
  role          String?
  company       String?
  difficulty    String?
  interviewMode String?
  reportScore   Float?

  // ── Question Generation (Gemini) ──────────────────────────────────────────
  questionGenerationStatus        PipelineStatus        @default(PENDING)
  questionGenerationFailureReason PipelineFailureReason @default(NONE)
  questionGenerationLastError     String?
  questionGenerationAttemptCount  Int                   @default(0)
  questionGenerationRetryCount    Int                   @default(0)
  questionGenerationStartedAt     DateTime?
  questionGenerationCompletedAt   DateTime?
  questionGenerationDurationMs    Int                   @default(0)
  questionGenerationProvider      String                @default("Gemini")
  geminiModel                     String?
  geminiInputTokens               Int                   @default(0)
  geminiOutputTokens              Int                   @default(0)
  geminiTotalTokens               Int                   @default(0)
  geminiInputCostUsd              Decimal               @default(0) @db.Decimal(12, 8)
  geminiOutputCostUsd             Decimal               @default(0) @db.Decimal(12, 8)
  geminiTotalCostUsd              Decimal               @default(0) @db.Decimal(12, 8)

  // ── Voice Interview (Deepgram Voice Agent API) ────────────────────────────
  deepgramStatus        PipelineStatus        @default(PENDING)
  deepgramFailureReason PipelineFailureReason @default(NONE)
  deepgramLastError     String?
  deepgramAttemptCount  Int                   @default(0)
  deepgramRetryCount    Int                   @default(0)
  deepgramStartedAt     DateTime?
  deepgramCompletedAt   DateTime?
  deepgramDurationMs    Int                   @default(0)
  deepgramProvider      String                @default("Deepgram")
  deepgramModel         String?
  deepgramAudioSeconds  Float                 @default(0)
  deepgramCostUsd       Decimal               @default(0) @db.Decimal(12, 8)

  // ── Report Generation (Gemini) ────────────────────────────────────────────
  reportGenerationStatus        PipelineStatus        @default(PENDING)
  reportGenerationFailureReason PipelineFailureReason @default(NONE)
  reportGenerationLastError     String?
  reportGenerationAttemptCount  Int                   @default(0)
  reportGenerationRetryCount    Int                   @default(0)
  reportGenerationStartedAt     DateTime?
  reportGenerationCompletedAt   DateTime?
  reportGenerationDurationMs    Int                   @default(0)
  reportGenerationProvider      String                @default("Gemini")
  reportGeminiModel             String?
  reportInputTokens             Int                   @default(0)
  reportOutputTokens            Int                   @default(0)
  reportTotalTokens             Int                   @default(0)
  reportSizeBytes               Int                   @default(0)
  reportInputCostUsd            Decimal               @default(0) @db.Decimal(12, 8)
  reportOutputCostUsd           Decimal               @default(0) @db.Decimal(12, 8)
  reportTotalCostUsd            Decimal               @default(0) @db.Decimal(12, 8)

  // ── Cognee Save ───────────────────────────────────────────────────────────
  cogneeSaveStatus        PipelineStatus        @default(PENDING)
  cogneeSaveFailureReason PipelineFailureReason @default(NONE)
  cogneeSaveLastError     String?
  cogneeSaveAttemptCount  Int                   @default(0)
  cogneeSaveRetryCount    Int                   @default(0)
  cogneeSaveStartedAt     DateTime?
  cogneeSaveCompletedAt   DateTime?
  cogneeSaveDurationMs    Int                   @default(0)
  cogneeProvider          String                @default("Cognee")
  cogneeNodesCreated      Int                   @default(0)
  cogneeEdgesCreated      Int                   @default(0)
  cogneeSaveCostUsd       Decimal               @default(0) @db.Decimal(12, 8)

  // ── Cognee Retrieval ──────────────────────────────────────────────────────
  cogneeRetrievalStatus        PipelineStatus        @default(PENDING)
  cogneeRetrievalFailureReason PipelineFailureReason @default(NONE)
  cogneeRetrievalLastError     String?
  cogneeRetrievalAttemptCount  Int                   @default(0)
  cogneeRetrievalRetryCount    Int                   @default(0)
  cogneeRetrievalStartedAt     DateTime?
  cogneeRetrievalCompletedAt   DateTime?
  cogneeRetrievalDurationMs    Int                   @default(0)
  cogneeRetrievedNodes         Int                   @default(0)
  cogneeRetrievedEdges         Int                   @default(0)
  cogneeRetrievalCostUsd       Decimal               @default(0) @db.Decimal(12, 8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([interviewId])
  @@index([createdAt])
  @@index([pipelineStatus])
  @@index([questionGenerationStatus])
  @@index([reportGenerationStatus])
  @@index([deepgramStatus])
  @@index([cogneeSaveStatus])
  @@index([cogneeRetrievalStatus])
  @@index([isFirstInterview])
  @@index([userId, createdAt])
}
