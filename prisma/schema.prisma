generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InterviewStatus {
  PENDING
  GENERATING
  READY
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum InterviewMode {
  VOICE
  TEXT
  HYBRID
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id              String              @id @default(cuid())
  clerkId         String              @unique
  email           String              @unique
  fullName        String?
  profile         UserProfile?
  resumes         Resume[]
  jobDescriptions JobDescription[]
  interviews      Interview[]
  answers         Answer[]
  analytics       InterviewAnalytics?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([clerkId])
  @@index([email])
}

model UserProfile {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience             String?
  githubUrl              String?
  linkedinUrl            String?
  targetRole             String?
  preferredInterviewMode InterviewMode @default(VOICE)
  preferredDifficulty    Difficulty    @default(MEDIUM)
  targetCompanies        String[]
  interviewTypes         String[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([targetRole])
}

model Resume {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl          String
  originalFileName String
  storedFileName   String
  fileSize         Int
  mimeType         String
  pageCount        Int
  rawText          String
  uploadedAt       DateTime    @default(now())
  interviews       Interview[]

  @@index([userId])
  @@index([storedFileName])
  @@index([uploadedAt])
}

model JobDescription {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  title        String
  fileUrl      String?
  rawText      String?
  parsedSkills String[]
  uploadedAt   DateTime    @default(now())
  interviews   Interview[]

  @@index([userId])
  @@index([company])
  @@index([title])
  @@index([uploadedAt])
}

model Interview {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId         String?
  resume           Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescriptionId String?
  jobDescription   JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  company          String?
  companyType      String?
  customCompanyName String?
  role             String
  interviewType    String?
  difficulty       Difficulty?
  status           InterviewStatus @default(PENDING)
  startedAt        DateTime?
  endedAt          DateTime?
  questions        Json?
  answer           Answer?
  report           Report?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([userId, status, updatedAt])
  @@index([resumeId])
  @@index([jobDescriptionId])
  @@index([status])
  @@index([createdAt])
}

model Answer {
  id         String   @id @default(cuid())
  interviewId String  @unique
  interview  Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Report {
  id                  String    @id @default(cuid())
  interviewId         String    @unique
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  overallScore        Float
  technicalScore      Float
  communicationScore  Float
  confidenceScore     Float
  behavioralScore     Float
  problemSolvingScore Float
  strengths           String[]
  weaknesses          String[]
  missingTopics       String[]
  recommendations     String[]
  createdAt           DateTime  @default(now())

  @@index([overallScore])
  @@index([createdAt])
}

model InterviewAnalytics {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalInterviews Int      @default(0)
  averageScore    Float    @default(0)
  currentStreak   Int      @default(0)
  readinessScore  Float    @default(0)
  updatedAt       DateTime @updatedAt

  @@index([readinessScore])
}

// Tombstone: immutable record of a deleted account. Survives the hard-delete of
// the User row so we keep knowledge of who left and how much they used. Keyed on
// email (stable identity) — clerkId changes on every re-signup, so email is the
// anchor that stops "delete + re-create" from resetting the usage limit.
model AccountDeletionLog {
  id         String   @id @default(cuid())
  clerkId    String
  email      String
  fullName   String?
  usedCount  Int      @default(0)
  reason     String?
  source     String   @default("clerk-webhook")
  deletedAt  DateTime @default(now())

  @@index([clerkId])
  @@index([email])
  @@index([deletedAt])
}
